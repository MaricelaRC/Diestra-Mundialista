# Firebase config — los valores reales se obtienen en console.firebase.google.com
# Copia este archivo como .env.local y rellena cada variable.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# NOTA: La API key de Gemini NO va aquí. Vive como secret en Cloud Functions.
