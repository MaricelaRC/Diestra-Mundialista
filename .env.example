# Firebase config — los valores reales se obtienen en console.firebase.google.com
# (Project settings → General → Your apps → SDK setup → Config).
# Copia este archivo como .env.local y rellena cada variable.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Cloudinary — cuenta gratis en cloudinary.com. El cloud_name está en el
# Dashboard. El upload preset debe estar configurado como 'Unsigned' en
# Settings → Upload → Upload presets.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# NOTA: La API key de Gemini NO va aquí. Vive como secret en Cloud Functions.
# El API Secret de Cloudinary tampoco — solo el cloud_name es público y los
# uploads se hacen vía preset unsigned.
