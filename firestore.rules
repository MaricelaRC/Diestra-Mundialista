rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Doc admin: cada usuario solo puede leer el suyo. Sin escritura desde
    // clientes — los admins se crean vía seed-firestore.mjs o consola.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Catálogo de hoteles: lectura pública (la app pública consume sin auth).
    // Escritura solo si el user autenticado tiene un doc admin que incluye
    // el id del hotel en su lista de hotelIds.
    match /hoteles/{hotelId} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && hotelId in get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.hotelIds;
    }

    // Cualquier otra colección: bloqueada por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
